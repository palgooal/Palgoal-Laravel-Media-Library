{
    "name": "palgoal/media-library",
    "description": "Standalone reusable media library (upload, browse, picker) extracted from PalgooalWeb. Model + Controller + Migration + Routes + Views + JS, ready to drop into any Laravel 10/11/12 project.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "media", "media-library", "uploader", "file-manager"],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Palgoal\\MediaLibrary\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Palgoal\\MediaLibrary\\MediaLibraryServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}
